---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const translate = useTranslations(lang);
---

<Layout title={`${translate('emoticonsTitle')} | ${translate('title')}`}>
    <div class="container">
        <a href={`/${lang}/`} class="back-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            {translate('backBtn')}
        </a>

        <div class="header">
            <h1>{translate('emoticonsTitle')}</h1>
            <p>{translate('emoticonsDesc')}</p>
        </div>

        <div id="emoticons-container" class="emoticons-grid"
             data-failed={lang === 'zh' ? '加载表情包失败，请检查 R2 绑定设置。' : 'Failed to load emoticons. Please verify R2 settings.'}
             data-empty={lang === 'zh' ? '未在 R2 存储桶中找到表情包。' : 'No emoticons found in R2.'}
        >
            <div class="loading-spinner">
                <div class="spinner"></div>
                <p>{translate('loading')}</p>
            </div>
        </div>
    </div>

    <div id="toast" class="toast" data-success={translate('copySuccess')} data-linkcopied={translate('linkCopied')}>
        {translate('copySuccess')}
    </div>
</Layout>

<style>
  .header {
    text-align: center;
    margin-bottom: 40px;
  }
  .header h1 {
    font-size: 2.5em;
    font-weight: 900;
    background: linear-gradient(135deg, var(--primary-color), var(--text-muted));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 10px;
  }
  .header p {
    color: var(--text-muted);
    font-size: 1.1em;
    max-width: 600px;
    margin: 0 auto;
  }

  .emoticons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 15px;
    margin-top: 20px;
  }

  .loading-spinner {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted);
  }
  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--border-color);
    border-top: 4px solid var(--primary-color);
    border-radius: 50%;
    margin: 0 auto 15px auto;
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .emoticon-card {
    background: var(--card-bg);
    border-radius: 12px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.2s ease-in-out;
    position: relative;
    box-shadow: 0 4px 12px rgba(170, 114, 121, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .emoticon-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(255, 62, 114, 0.15);
    border-color: var(--primary-color);
    background: var(--hover-bg);
  }

  .emoticon-card img {
    width: 100%;
    max-width: 100px;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 8px;
  }

  .emoticon-card .emoticon-name {
    margin-top: 8px;
    font-size: 0.8em;
    color: var(--text-muted);
    text-align: center;
    word-break: break-all;
  }

  .toast {
    position: fixed;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--primary-color);
    color: white;
    padding: 12px 24px;
    border-radius: 30px;
    box-shadow: 0 6px 20px rgba(255, 62, 114, 0.3);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    font-weight: 700;
    font-size: 0.95em;
    letter-spacing: 0.5px;
  }

  .toast.show {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
    interface Emoticon {
        key: string;
        url: string;
    }

    async function fetchEmoticons() {
        const container = document.getElementById('emoticons-container') as HTMLDivElement | null;
        const toast = document.getElementById('toast') as HTMLDivElement | null;

        if (!container) return;

        try {
            const response = await fetch('/api/emoticons');
            if (!response.ok) throw new Error('Failed to fetch emoticons');

            const emoticons: Emoticon[] = await response.json();

            container.innerHTML = '';
            if (emoticons.length === 0) {
                const emptyText = container.dataset.empty || "No emoticons found.";
                container.innerHTML = `<div style="grid-column: 1/-1; text-align: center; color: var(--text-muted);">${emptyText}</div>`;
                return;
            }

            emoticons.forEach(emo => {
                const card = document.createElement('div');
                card.className = 'emoticon-card';
                card.title = 'Click to copy to clipboard';

                const rawName = emo.key.split('/').pop() || emo.key;
                const name = rawName.split('.').slice(0, -1).join('.').replace(/_/g, ' ');

                card.innerHTML = `
                    <img src="${emo.url}" alt="${name}" loading="lazy">
                    <div class="emoticon-name">${name}</div>
                `;

                card.addEventListener('click', async () => {
                    try {
                        const imgRes = await fetch(emo.url);
                        const blob = await imgRes.blob();

                        if (typeof ClipboardItem !== 'undefined') {
                            try {
                                let copyBlob = blob;
                                
                                if (blob.type === 'image/svg+xml' || emo.url.includes('.svg')) {
                                    const img = new Image();
                                    img.src = URL.createObjectURL(blob);
                                    await new Promise((resolve, reject) => {
                                        img.onload = resolve;
                                        img.onerror = reject;
                                    });

                                    const canvas = document.createElement('canvas');
                                    canvas.width = img.naturalWidth;
                                    canvas.height = img.naturalHeight;
                                    const ctx = canvas.getContext('2d');
                                    if (ctx) {
                                        ctx.drawImage(img, 0, 0);
                                        const pngBlob = await new Promise<Blob | null>(res => canvas.toBlob(res, 'image/png'));
                                        if (pngBlob) copyBlob = pngBlob;
                                    }
                                }

                                const data = [new ClipboardItem({ [copyBlob.type]: copyBlob })];
                                await navigator.clipboard.write(data);

                                if (toast) {
                                    const successText = toast.dataset.success || 'Copied to clipboard!';
                                    toast.innerText = successText;
                                    toast.classList.add('show');
                                    setTimeout(() => toast.classList.remove('show'), 2000);
                                }
                                return;
                            } catch (clipboardErr) {
                                console.warn('ClipboardItem write failed, falling back to URL copy', clipboardErr);
                            }
                        }

                        // Fallback to copying URL text
                        await navigator.clipboard.writeText(window.location.origin + emo.url);
                        if (toast) {
                            const linkCopiedText = toast.dataset.linkcopied || 'Link copied!';
                            toast.innerText = linkCopiedText;
                            toast.classList.add('show');
                            setTimeout(() => toast.classList.remove('show'), 2000);
                        }

                    } catch (err) {
                        console.error('Failed to copy emoticon: ', err);
                    }
                });

                container.appendChild(card);
            });
        } catch (err) {
            const failedText = container.dataset.failed || "Failed to load emoticons.";
            container.innerHTML = `<div style="grid-column: 1/-1; text-align: center; color: var(--primary-color);">${failedText}</div>`;
            console.error(err);
        }
    }

    fetchEmoticons();
</script>
