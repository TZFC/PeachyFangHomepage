---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import '../../styles/home.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const translate = useTranslations(lang);
---

<Layout title={translate('wealthTitle')}>
  <div class="container wealth-container">
    <div class="header" style="margin-bottom: 2rem;">
      <a href={`/${lang}/`} class="btn" style="margin-bottom: 1rem; display: inline-block;">
        &larr; {translate('backBtn')}
      </a>
      <h1>{translate('wealthTitle')}</h1>
      <p class="desc">{translate('wealthDesc')}</p>
    </div>

    <div class="wealth-layout">
      <!-- Left: Logs -->
      <div class="wealth-logs" id="logContainer">
        <!-- Logs will be injected here via JS -->
      </div>

      <!-- Center: Pie Chart -->
      <div class="wealth-pie-container">
        <div class="pie-chart" id="pieChart"></div>
        <div class="pie-labels">
          <div class="label-red"><span class="color-box bg-red"></span> <span id="labelWealthy">{translate('wealthLabelWealthy')}</span></div>
          <div class="label-blue"><span class="color-box bg-blue"></span> <span id="labelWorker">{translate('wealthLabelWorker')}</span></div>
        </div>
      </div>

      <!-- Right: Controls -->
      <div class="wealth-controls">
        <div style="display: flex; justify-content: flex-end; margin-bottom: 0.5rem;">
          <button id="resetBtn" class="btn" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">{translate('wealthResetBtn')}</button>
        </div>
        <div class="control-group">
          <label for="initialWealthy">{translate('wealthInitialWealthy')}</label>
          <div class="slider-row">
            <input type="range" id="initialWealthy" min="0" max="100" value="95" step="1" />
            <input type="number" id="initialWealthyNum" min="0" max="100" value="95" />
          </div>
        </div>
        <div class="control-group">
          <label for="growthRate">{translate('wealthGrowthRate')}</label>
          <div class="slider-row">
            <input type="range" id="growthRate" min="0" max="100" value="10" step="1" />
            <input type="number" id="growthRateNum" min="0" max="100" value="10" />
          </div>
        </div>
        
        <div class="control-group">
          <label for="wealthTax">{translate('wealthTaxRate')}</label>
          <div class="slider-row">
            <input type="range" id="wealthTax" min="0" max="100" value="0" step="1" />
            <input type="number" id="wealthTaxNum" min="0" max="100" value="0" />
          </div>
        </div>
        
        <div class="control-group">
          <label for="paycheck">{translate('wealthPaycheck')}</label>
          <div class="slider-row">
            <input type="range" id="paycheck" min="0" max="10" value="1" step="0.1" />
            <input type="number" id="paycheckNum" min="0" max="10" value="1" step="0.1" />
          </div>
        </div>
        
        <div class="control-group">
          <label for="incomeTax">{translate('wealthIncomeTaxRate')}</label>
          <div class="slider-row">
            <input type="range" id="incomeTax" min="0" max="100" value="30" step="1" />
            <input type="number" id="incomeTaxNum" min="0" max="100" value="30" />
          </div>
        </div>
        
        <div class="control-group">
          <label for="expense">{translate('wealthExpense')}</label>
          <div class="slider-row">
            <input type="range" id="expense" min="0" max="10" value="1" step="0.1" />
            <input type="number" id="expenseNum" min="0" max="10" value="1" step="0.1" />
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom: Time Slider -->
    <div class="time-control">
      <label for="yearSlider">{translate('wealthYearLabel')}</label>
      <div class="slider-row large-slider">
        <input type="range" id="yearSlider" min="0" max="200" value="0" step="1" />
        <input type="number" id="yearNum" class="year-display" min="0" max="200" value="0" />
      </div>
    </div>
  </div>
</Layout>

<style>
  .wealth-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  .wealth-layout {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    align-items: start;
    margin-bottom: 3rem;
  }
  
  @media (max-width: 900px) {
    .wealth-layout {
      grid-template-columns: 1fr;
    }
    
    .wealth-pie-container {
      position: sticky;
      top: 1rem;
      z-index: 10;
      height: auto;
      padding: 1.5rem;
      background: rgba(30, 30, 30, 0.7);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    
    .pie-chart {
      width: 200px;
      height: 200px;
    }
    
    .pie-labels {
      margin-top: 1rem;
      font-size: 0.9rem;
      gap: 1rem;
    }
  }

  /* Logs Panel */
  .wealth-logs {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    height: 400px;
    overflow-y: auto;
    font-size: 0.95rem;
    line-height: 1.6;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    backdrop-filter: blur(10px);
  }
  
  .log-year {
    font-weight: bold;
    color: var(--accent-color, #ff6b6b);
    margin-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.25rem;
  }

  .log-entry {
    margin-bottom: 0.5rem;
  }

  /* Pie Chart */
  .wealth-pie-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 400px;
  }
  
  .pie-chart {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: conic-gradient(#ff4757 0% 80%, #1e90ff 80% 100%);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3), inset 0 0 20px rgba(0,0,0,0.5);
    border: 4px solid rgba(255,255,255,0.1);
    
    /* Fix for background bleeding under border & jagged clipping */
    overflow: hidden;
    background-clip: padding-box;
    -webkit-mask-image: -webkit-radial-gradient(white, black);
    transform: translateZ(0);
  }
  
  .pie-labels {
    display: flex;
    gap: 2rem;
    margin-top: 1.5rem;
    font-weight: bold;
  }
  
  .color-box {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    margin-right: 8px;
    vertical-align: middle;
  }
  
  .bg-red { background: #ff4757; }
  .bg-blue { background: #1e90ff; }
  
  .label-red { color: #ff4757; }
  .label-blue { color: #1e90ff; }

  /* Controls */
  .wealth-controls {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.5rem;
    height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backdrop-filter: blur(10px);
  }
  
  .control-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .control-group label {
    font-weight: 600;
    font-size: 0.95rem;
  }
  
  .slider-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  input[type=range] {
    flex-grow: 1;
    cursor: pointer;
    accent-color: var(--accent-color, #ff6b6b);
  }
  
  input[type=number] {
    width: 70px;
    padding: 0.5rem;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.3);
    color: white;
    font-family: inherit;
    text-align: center;
  }
  
  /* Time Control */
  .time-control {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
  }
  
  .time-control label {
    display: block;
    font-size: 1.2rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
  }
  
  .large-slider {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .large-slider input[type=range] {
    height: 8px;
  }
  
  .year-display {
    font-size: 2rem;
    font-weight: bold;
    background: rgba(255,255,255,0.1);
    padding: 0.5rem 1.5rem;
    border-radius: 8px;
    min-width: 80px;
    width: 140px;
    text-align: center;
    color: var(--accent-color, #ff6b6b);
    border: 1px solid rgba(255,255,255,0.2);
    font-family: inherit;
  }
  
  .year-display:focus {
    outline: none;
    border-color: var(--accent-color, #ff6b6b);
  }
</style>

<div id="i18n-data" style="display:none;" 
  data-year={translate('wealthYear')}
  data-initial={translate('wealthLogInitial')}
  data-interest={translate('wealthLogInterest')}
  data-wealthtax={translate('wealthLogWealthTax')}
  data-paycheck={translate('wealthLogPaycheck')}
  data-incometax={translate('wealthLogIncomeTax')}
  data-welfare={translate('wealthLogWelfare')}
  data-ratio={translate('wealthLogRatio')}
  data-expense={translate('wealthLogExpense')}
  data-wealthy={translate('wealthLabelWealthy')}
  data-worker={translate('wealthLabelWorker')}
></div>

<script src="../../scripts/wealth.ts"></script>
