---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/base.css';
import '../styles/components.css';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
}

const { title, description, keywords } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const translate = useTranslations(lang);

const finalDesc = description || translate('metaDesc');
const finalKeywords = keywords || translate('metaKeywords');
const siteUrl = "https://peachyfang.muxiaokongh.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const nextLang = lang === 'zh' ? 'en' : 'zh';
const nextLangLabel = lang === 'zh' ? 'EN' : '简';
const targetPath = Astro.url.pathname.replace(`/${lang}`, `/${nextLang}`);

const schemaMarkup = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "PeachyFang",
    "alternateName": ["天子方辰", "Peachy", "Fang"],
    "description": finalDesc,
    "url": siteUrl,
    "sameAs": [
        "https://live.bilibili.com/23596840",
    ],
    "knowsLanguage": ["zh-CN", "en-US"]
};
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en-US'}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={finalDesc} />
    <meta name="keywords" content={finalKeywords} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    
    <meta name="theme-color" content="#ff3e72" />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaMarkup)} />
    <style is:global>
        @media (display-mode: standalone) {
            .top-bar, .footer {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="bg-image"></div>
    <div class="center-blur-mask">
        <div class="blur-effect-core"></div>
    </div>
    
    <div class="top-bar">
        <button id="theme-toggle" class="icon-btn" title="Toggle Dark Mode">🌙</button>
        <a id="lang-toggle" href={targetPath} class="icon-btn" title="Switch Language" style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">{nextLangLabel}</a>
    </div>

    <slot />

    <div class="footer">
        <strong>PeachyFang © 2026</strong><br>
        <span>Hosted at peachyfang.muxiaokongh.com | Developed with ❤️</span>
    </div>

    <script is:inline>
        // --- Theme Management ---
        const themeToggleBtn = document.getElementById('theme-toggle');
        const savedTheme = localStorage.getItem('siteTheme');
        
        let isDark;
        if (savedTheme) {
            isDark = savedTheme === 'dark';
        } else {
            isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        }
        
        function applyTheme() {
            if (isDark) {
                document.body.classList.add('dark-mode');
                if (themeToggleBtn) themeToggleBtn.innerText = '☀️';
            } else {
                document.body.classList.remove('dark-mode');
                if (themeToggleBtn) themeToggleBtn.innerText = '🌙';
            }
        }

        applyTheme();

        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', () => {
                isDark = !isDark;
                localStorage.setItem('siteTheme', isDark ? 'dark' : 'light');
                applyTheme();
            });
        }

        // Lang switch preference
        const langToggleBtn = document.getElementById('lang-toggle');
        if (langToggleBtn) {
            langToggleBtn.addEventListener('click', function() {
                const href = langToggleBtn.getAttribute('href') || '';
                const nextLangVal = new URL(href, window.location.origin).pathname.split('/')[1];
                localStorage.setItem('siteLang', nextLangVal);
            });
        }
    </script>
</body>
</html>
